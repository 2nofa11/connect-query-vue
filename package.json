{
  "name": "connect-query-vue",
  "version": "0.0.8",
  "description": "Vue adapter for connect-query-core, bringing Connect RPC support to @tanstack/vue-query",
  "homepage": "https://github.com/2nofa11/connect-query-vue#readme",
  "bugs": {
    "url": "https://github.com/2nofa11/connect-query-vue/issues"
  },
  "license": "MIT",
  "author": "2nofa11",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2nofa11/connect-query-vue.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "vp pack"
  },
  "dependencies": {
    "@connectrpc/connect-query-core": "2.2.0"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@connectrpc/connect": "2.1.1",
    "@tanstack/vue-query": "5.99.2",
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260420.1",
    "@vue/test-utils": "2.4.6",
    "bumpp": "^11.0.1",
    "happy-dom": "^20.8.4",
    "test-utils": "file:connect-query-es/packages/test-utils",
    "typescript": "^6.0.2",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vue": "3.5.32"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": "2.x",
    "@connectrpc/connect": "2.x",
    "@tanstack/vue-query": ">=5.62.0",
    "vue": ">=3.3.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
